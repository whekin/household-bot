# Bot runtime
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# Database
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres
DB_SCHEMA=public

# Telegram bot and webhook
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_WEBHOOK_PATH=/webhook/telegram

# Public URLs
# Telegram links to this URL from /app and /dashboard.
MINI_APP_URL=https://your-miniapp-domain.example
# Injected into the mini app container as its API base URL.
BOT_API_URL=https://your-bot-domain.example
# Allowed mini app API origins, comma-separated.
MINI_APP_ALLOWED_ORIGINS=http://localhost:5173

# Household agent
# Without an API key, conversational and text-purchase handling is disabled.
OPENAI_API_KEY=your-openai-api-key
ASSISTANT_MODEL=gpt-5.6-terra
ASSISTANT_TIMEOUT_MS=20000
ASSISTANT_MEMORY_MAX_TURNS=12
ASSISTANT_RATE_LIMIT_BURST=5
ASSISTANT_RATE_LIMIT_BURST_WINDOW_MS=60000
ASSISTANT_RATE_LIMIT_ROLLING=50
ASSISTANT_RATE_LIMIT_ROLLING_WINDOW_MS=86400000

# Scheduler authentication
SCHEDULER_SHARED_SECRET=your-scheduler-shared-secret
SCHEDULER_OIDC_ALLOWED_EMAILS=

# Self-hosted scheduler runner
# docker-compose.coolify.yml supplies BOT_INTERNAL_BASE_URL internally.
SCHEDULER_POLL_INTERVAL_MS=60000
SCHEDULER_DUE_SCAN_LIMIT=25

# Scheduled dispatch provider
# Leave blank to disable scheduled dispatch locally.
# Options: self-hosted, gcp-cloud-tasks, aws-eventbridge.
SCHEDULED_DISPATCH_PROVIDER=

# GCP Cloud Tasks
SCHEDULED_DISPATCH_PUBLIC_BASE_URL=
GCP_SCHEDULED_DISPATCH_PROJECT_ID=
GCP_SCHEDULED_DISPATCH_LOCATION=
GCP_SCHEDULED_DISPATCH_QUEUE=

# AWS EventBridge Scheduler
AWS_SCHEDULED_DISPATCH_REGION=
AWS_SCHEDULED_DISPATCH_TARGET_LAMBDA_ARN=
AWS_SCHEDULED_DISPATCH_ROLE_ARN=
AWS_SCHEDULED_DISPATCH_GROUP_NAME=

# Operator scripts (not consumed by the bot runtime)
# Used by `bun run ops:telegram:webhook set`.
TELEGRAM_WEBHOOK_URL=https://your-bot-domain.example/webhook/telegram
# Used by `bun run ops:deploy:smoke` together with BOT_API_URL and MINI_APP_URL.
TELEGRAM_EXPECTED_WEBHOOK_URL=https://your-bot-domain.example/webhook/telegram
# Optional Telegram webhook controls.
TELEGRAM_MAX_CONNECTIONS=
TELEGRAM_DROP_PENDING_UPDATES=
