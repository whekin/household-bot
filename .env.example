# Core
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# Database
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres
DB_SCHEMA=public

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_WEBHOOK_PATH=/webhook/telegram

# Mini app
# URL for /app and /dashboard commands (e.g., https://your-app.cloud.run)
MINI_APP_URL=https://your-miniapp-domain.com
# CORS origins for mini app API (comma-separated)
MINI_APP_ALLOWED_ORIGINS=http://localhost:5173

# Parsing / AI
OPENAI_API_KEY=your-openai-api-key
PURCHASE_PARSER_MODEL=gpt-5.4-mini
ASSISTANT_MODEL=gpt-5.4-mini
TOPIC_PROCESSOR_MODEL=gpt-4.1-nano
TOPIC_PROCESSOR_TIMEOUT_MS=10000
ASSISTANT_TIMEOUT_MS=20000
ASSISTANT_MEMORY_MAX_TURNS=12
ASSISTANT_RATE_LIMIT_BURST=5
ASSISTANT_RATE_LIMIT_BURST_WINDOW_MS=60000
ASSISTANT_RATE_LIMIT_ROLLING=50
ASSISTANT_RATE_LIMIT_ROLLING_WINDOW_MS=86400000

# Scheduler
SCHEDULER_SHARED_SECRET=your-scheduler-shared-secret
SCHEDULER_OIDC_ALLOWED_EMAILS=scheduler-invoker@your-project.iam.gserviceaccount.com

# Scheduled dispatches
# Leave blank to disable scheduled dispatch locally.
# Options:
# - self-hosted        (VPS / Docker Compose poller)
# - gcp-cloud-tasks    (Cloud Run / GCP)
# - aws-eventbridge    (AWS)
SCHEDULED_DISPATCH_PROVIDER=

# GCP Cloud Tasks
SCHEDULED_DISPATCH_PUBLIC_BASE_URL=
GCP_SCHEDULED_DISPATCH_PROJECT_ID=
GCP_SCHEDULED_DISPATCH_LOCATION=
GCP_SCHEDULED_DISPATCH_QUEUE=

# AWS EventBridge Scheduler
AWS_SCHEDULED_DISPATCH_REGION=
AWS_SCHEDULED_DISPATCH_TARGET_LAMBDA_ARN=
AWS_SCHEDULED_DISPATCH_ROLE_ARN=
AWS_SCHEDULED_DISPATCH_GROUP_NAME=
